{"type":"tool_use","timestamp":"2026-06-15T15:12:23.329Z","tool_name":"replace","tool_id":"replace__replace_1781536343324_0","parameters":{"instruction":"Add scaling by the number of categories to SoftmaxSamplingActivation to prevent signal attenuation.","new_string":"class SoftmaxSamplingActivation(nn.Module):\n    \"\"\"\n    Softmax Sampling Activation (SSA).\n    Treats activations as logits, computes a softmax distribution over them,\n    and samples using the Gumbel-Softmax trick.\n    Includes scaling by number of categories to maintain signal magnitude.\n    \"\"\"\n    def __init__(self, tau=1.0, hard=False, dim=1, scale=True):\n        super(SoftmaxSamplingActivation, self).__init__()\n        self.tau = tau\n        self.hard = hard\n        self.dim = dim\n        self.scale = scale\n\n    def forward(self, x):\n        num_categories = x.shape[self.dim]\n        if self.training:\n            weights = F.gumbel_softmax(x, tau=self.tau, hard=self.hard, dim=self.dim)\n            y = weights * x\n            if self.scale:\n                y = y * num_categories\n            return y\n        else:\n            if self.hard:\n                probs = F.softmax(x, dim=self.dim)\n                shape = probs.shape\n                flat_probs = probs.view(-1, shape[self.dim])\n                # Use argmax for deterministic inference if desired, or multinomial for true sampling\n                sampled_idx = torch.argmax(flat_probs, dim=1).view(*[shape[i] if i != self.dim else 1 for i in range(len(shape))])\n                mask = torch.zeros_like(probs).scatter_(self.dim, sampled_idx, 1.0)\n                y = mask * x\n                if self.scale:\n                    y = y * num_categories\n                return y\n            else:\n                y = F.softmax(x, dim=self.dim) * x\n                if self.scale:\n                    y = y * num_categories\n                return y\n","file_path":"src/ssa.py","old_string":"class SoftmaxSamplingActivation(nn.Module):\n    \"\"\"\n    Softmax Sampling Activation (SSA).\n    Treats activations as logits, computes a softmax distribution over them,\n    and samples using the Gumbel-Softmax trick.\n    \"\"\"\n    def __init__(self, tau=1.0, hard=False, dim=1):\n        super(SoftmaxSamplingActivation, self).__init__()\n        self.tau = tau\n        self.hard = hard\n        self.dim = dim\n\n    def forward(self, x):\n        if self.training:\n            # During training, we use Gumbel-Softmax to allow gradients to flow.\n            # We treat the dimension `dim` (usually channels) as categories.\n            weights = F.gumbel_softmax(x, tau=self.tau, hard=self.hard, dim=self.dim)\n            return weights * x\n        else:\n            # During inference, we can either use the hard sample (most likely)\n            # or the expected value (softmax).\n            # Following the \"sampling\" spirit, let's use hard sampling if self.hard is True.\n            if self.hard:\n                # Sample from categorical\n                probs = F.softmax(x, dim=self.dim)\n                shape = probs.shape\n                # Flatten spatial dimensions if needed\n                flat_probs = probs.view(-1, shape[self.dim])\n                sampled_idx = torch.multinomial(flat_probs, 1).view(*[shape[i] if i != self.dim else 1 for i in range(len(shape))])\n                \n                # Create one-hot mask\n                mask = torch.zeros_like(probs).scatter_(self.dim, sampled_idx, 1.0)\n                return mask * x\n            else:\n                # Use softmax as a soft approximation\n                return F.softmax(x, dim=self.dim) * x\n"}}
